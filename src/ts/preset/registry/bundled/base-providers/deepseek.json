{
  "id": "deepseek",
  "version": 1,
  "displayName": "DeepSeek",
  "adapterKind": "openai-compatible",
  "authKinds": [
    "bearer"
  ],
  "endpointKinds": [
    "static"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json"
  },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "DeepSeek API key from platform.deepseek.com.",
      "required": true,
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "DeepSeek API 키."
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      }
    ]
  },
  "capabilities": [
    "streaming",
    "reasoning",
    "tools",
    "json"
  ],
  "sourceUrls": [
    "https://platform.deepseek.com/api_keys",
    "https://api-docs.deepseek.com/quick_start/pricing",
    "https://api-docs.deepseek.com/api/create-chat-completion"
  ]
}
