{
  "id": "ollama-cloud",
  "version": 2,
  "displayName": "Ollama Cloud",
  "adapterKind": "openai-compatible",
  "authKinds": [
    "bearer"
  ],
  "endpointKinds": [
    "static"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json"
  },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "Generate at ollama.com/settings/keys.",
      "required": true,
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "ollama.com/settings/keys 에서 발급."
      }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Cloud-hosted model. Local Ollama cloud models commonly use the :cloud suffix (e.g. gpt-oss:120b-cloud), while direct ollama.com API examples may use the bare model name (e.g. gpt-oss:120b). See https://ollama.com/search?c=cloud for the current list.",
      "required": true,
      "enum": [
        {
          "value": "glm-5.1:cloud",
          "label": "GLM 5.1"
        },
        {
          "value": "kimi-k2.6:cloud",
          "label": "Kimi K2.6"
        },
        {
          "value": "gemma4:31b-cloud",
          "label": "Gemma 4 31B"
        },
        {
          "value": "gemini-3-flash-preview:cloud",
          "label": "Gemini 3 Flash"
        },
        {
          "value": "gpt-oss:120b-cloud",
          "label": "gpt-oss 120B"
        },
        {
          "value": "gpt-oss:20b-cloud",
          "label": "gpt-oss 20B"
        },
        {
          "value": "deepseek-v4-pro:cloud",
          "label": "DeepSeek V4 Pro"
        },
        {
          "value": "deepseek-v4-flash:cloud",
          "label": "DeepSeek V4 Flash"
        },
        {
          "value": "qwen3.5:397b-cloud",
          "label": "Qwen3.5 397B"
        },
        {
          "value": "minimax-m3:cloud",
          "label": "MiniMax M3"
        },
        {
          "value": "glm-4.7:cloud",
          "label": "GLM 4.7"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "클라우드 호스팅 모델. 로컬 Ollama의 클라우드 모델은 보통 :cloud 접미사를 사용하지만(예: gpt-oss:120b-cloud), ollama.com 직접 API 예시는 접미사 없는 모델명도 사용합니다(예: gpt-oss:120b). 최신 목록은 https://ollama.com/search?c=cloud 참조."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "top_k",
      "type": "integer",
      "label": "Top K",
      "min": 0,
      "max": 500,
      "mapsTo": {
        "target": "body",
        "path": "top_k"
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "min": 1,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      },
      "default": 8192
    },
    {
      "key": "stop",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop"
      }
    },
    {
      "key": "seed",
      "type": "integer",
      "label": "Seed",
      "mapsTo": {
        "target": "body",
        "path": "seed"
      }
    },
    {
      "key": "reasoning_effort",
      "type": "string",
      "label": "Reasoning Effort",
      "description": "Reasoning depth for thinking models (gpt-oss, etc.). 'none' disables thinking.",
      "enum": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "reasoning_effort"
      },
      "descriptionI18n": {
        "ko": "추론(사고) 강도. gpt-oss 등 thinking 모델에 적용 (none은 비활성)."
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 2,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 3,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 4,
        "labelI18n": {
          "ko": "추론"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1,
        "placeholder": "gpt-oss:120b-cloud"
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "top_k",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "stop",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "seed",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 6
      },
      {
        "key": "reasoning_effort",
        "widget": "combobox",
        "visibility": "basic",
        "group": "reasoning",
        "order": 1
      }
    ]
  },
  "capabilities": [
    "streaming"
  ],
  "sourceUrls": [
    "https://docs.ollama.com/cloud",
    "https://ollama.com/search?c=cloud",
    "https://docs.ollama.com/api/openai-compatibility"
  ],
  "limits": {
    "known": false,
    "sourceUrls": [
      "https://docs.ollama.com/cloud",
      "https://ollama.com/search?c=cloud",
      "https://docs.ollama.com/api/openai-compatibility"
    ],
    "notes": "Model-dependent provider. Context and output token limits vary by selected model or deployment, so 小酒馆 uses a number input instead of a fixed-limit slider."
  }
}
