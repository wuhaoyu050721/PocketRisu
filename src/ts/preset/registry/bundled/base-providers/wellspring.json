{
  "id": "wellspring",
  "version": 1,
  "displayName": "Wellspring",
  "adapterKind": "openai-compatible",
  "authKinds": [
    "bearer"
  ],
  "endpointKinds": [
    "static"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json"
  },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "Wellspring API key (ws-...). Bound to your arca.live account.",
      "required": true,
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "Wellspring(챈섭) API 키 (ws-...). arca.live 계정에 연동됩니다."
      }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Model identifier accepted by Wellspring.",
      "required": true,
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "Wellspring(챈섭)이 허용하는 모델 ID."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "min": 1,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      },
      "default": 4096
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "frequency_penalty",
      "type": "number",
      "label": "Frequency Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "frequency_penalty"
      }
    },
    {
      "key": "presence_penalty",
      "type": "number",
      "label": "Presence Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "presence_penalty"
      }
    },
    {
      "key": "stop",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop"
      }
    },
    {
      "key": "seed",
      "type": "integer",
      "label": "Seed",
      "mapsTo": {
        "target": "body",
        "path": "seed"
      }
    },
    {
      "key": "reasoning_effort",
      "type": "string",
      "label": "Reasoning Effort",
      "description": "Unified reasoning depth knob (Wellspring gateway). 'none' disables thinking; 'max' is the deepest. Only applies to reasoning-capable models.",
      "enum": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "high",
          "label": "High"
        },
        {
          "value": "max",
          "label": "Max"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "reasoning_effort"
      },
      "descriptionI18n": {
        "ko": "통합 추론 강도 (Wellspring 게이트웨이). none은 thinking 끄기, max가 가장 깊음. reasoning 지원 모델에만 적용."
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 2,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 3,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 4,
        "labelI18n": {
          "ko": "추론"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "frequency_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "presence_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "stop",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 6
      },
      {
        "key": "seed",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 7
      },
      {
        "key": "reasoning_effort",
        "widget": "combobox",
        "visibility": "basic",
        "group": "reasoning",
        "order": 1
      }
    ]
  },
  "capabilities": [
    "streaming"
  ],
  "sourceUrls": [
    "https://wellspring.encrypt.gay/v1/models"
  ],
  "limits": {
    "known": false,
    "sourceUrls": [
      "https://wellspring.encrypt.gay/v1/models"
    ],
    "notes": "Community-run arca.live API. Wellspring enforces a per-request input cap (max_input_tokens) and per-model output/RPM limits exposed via /v1/models/{id}; per-profile limits below reflect those host-enforced caps, not native model context windows."
  }
}
