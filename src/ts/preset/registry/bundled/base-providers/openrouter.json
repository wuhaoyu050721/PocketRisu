{
  "id": "openrouter",
  "version": 1,
  "displayName": "OpenRouter",
  "adapterKind": "openai-compatible",
  "authKinds": [
    "bearer"
  ],
  "endpointKinds": [
    "static"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json"
  },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "OpenRouter API key (`sk-or-...`).",
      "required": true,
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "OpenRouter API 키 (`sk-or-...`)."
      }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Vendor/model identifier (e.g. anthropic/claude-sonnet-4-5).",
      "required": true,
      "enum": [
        {
          "value": "openrouter/auto",
          "label": "OpenRouter Auto"
        },
        {
          "value": "openai/gpt-5",
          "label": "OpenAI / GPT-5"
        },
        {
          "value": "anthropic/claude-sonnet-4-5",
          "label": "Anthropic / Claude Sonnet 4.5"
        },
        {
          "value": "anthropic/claude-opus-4-1",
          "label": "Anthropic / Claude Opus 4.1"
        },
        {
          "value": "google/gemini-2.5-pro",
          "label": "Google / Gemini 2.5 Pro"
        },
        {
          "value": "google/gemini-2.5-flash",
          "label": "Google / Gemini 2.5 Flash"
        },
        {
          "value": "deepseek/deepseek-chat",
          "label": "DeepSeek / Chat"
        },
        {
          "value": "deepseek/deepseek-reasoner",
          "label": "DeepSeek / Reasoner"
        },
        {
          "value": "meta-llama/llama-3.3-70b-instruct",
          "label": "Meta / Llama 3.3 70B"
        },
        {
          "value": "qwen/qwen-3-235b",
          "label": "Qwen 3 235B"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "공급자/모델 ID (예: anthropic/claude-sonnet-4-5)."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "min": 1,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      },
      "default": 8192
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "top_k",
      "type": "integer",
      "label": "Top K",
      "min": 0,
      "max": 500,
      "mapsTo": {
        "target": "body",
        "path": "top_k"
      }
    },
    {
      "key": "min_p",
      "type": "number",
      "label": "Min P",
      "min": 0,
      "max": 1,
      "step": 0.001,
      "mapsTo": {
        "target": "body",
        "path": "min_p"
      }
    },
    {
      "key": "top_a",
      "type": "number",
      "label": "Top A",
      "min": 0,
      "max": 1,
      "step": 0.001,
      "mapsTo": {
        "target": "body",
        "path": "top_a"
      }
    },
    {
      "key": "frequency_penalty",
      "type": "number",
      "label": "Frequency Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "frequency_penalty"
      }
    },
    {
      "key": "presence_penalty",
      "type": "number",
      "label": "Presence Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "presence_penalty"
      }
    },
    {
      "key": "repetition_penalty",
      "type": "number",
      "label": "Repetition Penalty",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "repetition_penalty"
      }
    },
    {
      "key": "stop",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop"
      }
    },
    {
      "key": "seed",
      "type": "integer",
      "label": "Seed",
      "mapsTo": {
        "target": "body",
        "path": "seed"
      }
    },
    {
      "key": "reasoning_effort",
      "type": "string",
      "label": "Reasoning Effort",
      "description": "Forward reasoning hints to compatible models.",
      "enum": [
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        },
        {
          "value": "xhigh",
          "label": "Extra High"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "reasoning.effort"
      },
      "descriptionI18n": {
        "ko": "호환 모델에 reasoning 힌트를 전달합니다."
      }
    },
    {
      "key": "transforms",
      "type": "stringArray",
      "label": "Transforms",
      "description": "Content transforms (e.g. `middle-out` to compact long contexts).",
      "mapsTo": {
        "target": "body",
        "path": "transforms"
      },
      "descriptionI18n": {
        "ko": "컨텐츠 변환 (예: 긴 컨텍스트를 압축하는 `middle-out`)."
      }
    },
    {
      "key": "route",
      "type": "string",
      "label": "Route",
      "description": "Routing strategy.",
      "enum": [
        {
          "value": "fallback",
          "label": "Fallback"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "route"
      },
      "descriptionI18n": {
        "ko": "라우팅 전략."
      }
    },
    {
      "key": "models",
      "type": "stringArray",
      "label": "Fallback Models",
      "description": "Ordered fallback model list.",
      "mapsTo": {
        "target": "body",
        "path": "models"
      },
      "descriptionI18n": {
        "ko": "순서대로 시도할 fallback 모델 목록."
      }
    },
    {
      "key": "provider",
      "type": "json",
      "label": "Provider Preferences",
      "description": "Provider routing preferences (order, ignore, allow_fallbacks, ...).",
      "mapsTo": {
        "target": "body",
        "path": "provider"
      },
      "descriptionI18n": {
        "ko": "공급자 라우팅 설정 (order, ignore, allow_fallbacks 등)."
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 2,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 3,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 4,
        "labelI18n": {
          "ko": "추론"
        }
      },
      {
        "id": "routing",
        "label": "Routing",
        "order": 5,
        "labelI18n": {
          "ko": "라우팅"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1,
        "placeholder": "anthropic/claude-sonnet-4-5"
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "top_k",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "min_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "top_a",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 6
      },
      {
        "key": "frequency_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 7
      },
      {
        "key": "presence_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 8
      },
      {
        "key": "repetition_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 9
      },
      {
        "key": "stop",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 10
      },
      {
        "key": "seed",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 11
      },
      {
        "key": "reasoning_effort",
        "widget": "combobox",
        "visibility": "advanced",
        "group": "reasoning",
        "order": 1
      },
      {
        "key": "transforms",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "routing",
        "order": 1
      },
      {
        "key": "route",
        "widget": "select",
        "visibility": "advanced",
        "group": "routing",
        "order": 2
      },
      {
        "key": "models",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "routing",
        "order": 3
      },
      {
        "key": "provider",
        "widget": "json",
        "visibility": "advanced",
        "group": "routing",
        "order": 4
      }
    ]
  },
  "capabilities": [
    "streaming",
    "reasoning",
    "vision",
    "tools"
  ],
  "sourceUrls": [
    "https://openrouter.ai/docs",
    "https://raw.githubusercontent.com/vercel/ai/main/packages/openrouter-provider/"
  ],
  "limits": {
    "known": false,
    "sourceUrls": [
      "https://openrouter.ai/docs",
      "https://raw.githubusercontent.com/vercel/ai/main/packages/openrouter-provider/"
    ],
    "notes": "Model-dependent provider. Context and output token limits vary by selected model or deployment, so 小酒馆 uses a number input instead of a fixed-limit slider."
  }
}
