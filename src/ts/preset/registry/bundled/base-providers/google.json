{
  "id": "google",
  "version": 2,
  "displayName": "Google AI Studio (Gemini)",
  "adapterKind": "google-gemini",
  "authKinds": [
    "x-goog-api-key"
  ],
  "endpointKinds": [
    "static"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json"
  },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "Google AI Studio API key.",
      "required": true,
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "Google AI Studio API 키."
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      }
    ]
  },
  "capabilities": [
    "streaming",
    "reasoning",
    "vision",
    "tools",
    "json",
    "cache"
  ],
  "sourceUrls": [
    "https://ai.google.dev/gemini-api/docs/models",
    "https://ai.google.dev/api/generate-content"
  ]
}
