{
  "id": "anthropic-compatible",
  "version": 2,
  "displayName": "Anthropic Compatible (Custom)",
  "adapterKind": "anthropic-messages",
  "authKinds": [
    "x-api-key",
    "none"
  ],
  "endpointKinds": [
    "static"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json",
    "anthropic-version": "2023-06-01"
  },
  "defaultBody": {
    "max_tokens": 4096
  },
  "requestSchema": [
    {
      "key": "endpointUrl",
      "type": "string",
      "label": "Endpoint URL",
      "description": "Full Anthropic Messages URL (e.g. http://localhost:4141/v1/messages). Use for proxies that speak the Anthropic Messages wire format (GitHub Copilot bridges, LiteLLM Anthropic passthrough, etc.).",
      "required": true,
      "mapsTo": {
        "target": "custom",
        "path": "endpointUrl"
      },
      "descriptionI18n": {
        "ko": "전체 Anthropic Messages URL (예: http://localhost:4141/v1/messages). Anthropic Messages 포맷을 따르는 프록시용 (GitHub Copilot 브릿지, LiteLLM Anthropic 패스스루 등)."
      }
    },
    {
      "key": "apiKey",
      "type": "string",
      "label": "API Key",
      "description": "Sent as the x-api-key header. Leave empty only when using the no-auth profile.",
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "x-api-key 헤더로 전송됩니다. 인증 없는 프로파일을 쓸 때만 비워두세요."
      }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Model identifier accepted by the upstream endpoint (e.g. claude-fable-5). Suggestions are first-party Claude IDs; any value the upstream accepts can be typed.",
      "required": true,
      "enum": [
        {
          "value": "claude-fable-5",
          "label": "Claude Fable 5"
        },
        {
          "value": "claude-opus-4-8",
          "label": "Claude Opus 4.8"
        },
        {
          "value": "claude-sonnet-4-6",
          "label": "Claude Sonnet 4.6"
        },
        {
          "value": "claude-haiku-4-5",
          "label": "Claude Haiku 4.5"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "상위 엔드포인트가 허용하는 모델 ID (예: claude-fable-5). 제안 목록은 first-party Claude ID이며, 상위 엔드포인트가 허용하는 값이면 자유 입력 가능합니다."
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "description": "Anthropic Messages requires max_tokens on every request.",
      "min": 1,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      },
      "default": 4096,
      "descriptionI18n": {
        "ko": "Anthropic Messages는 모든 요청에 max_tokens가 필요합니다."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "top_k",
      "type": "integer",
      "label": "Top K",
      "min": 0,
      "max": 500,
      "mapsTo": {
        "target": "body",
        "path": "top_k"
      }
    },
    {
      "key": "stop_sequences",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop_sequences"
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "endpoint",
        "label": "Endpoint",
        "order": 1,
        "labelI18n": {
          "ko": "엔드포인트"
        }
      },
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 2,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 3,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 4,
        "labelI18n": {
          "ko": "생성"
        }
      }
    ],
    "fields": [
      {
        "key": "endpointUrl",
        "widget": "text",
        "visibility": "basic",
        "group": "endpoint",
        "order": 1,
        "placeholder": "http://localhost:4141/v1/messages"
      },
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "top_k",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "stop_sequences",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      }
    ]
  },
  "capabilities": [
    "streaming"
  ],
  "sourceUrls": [
    "https://platform.claude.com/docs/en/api/messages"
  ],
  "limits": {
    "known": false,
    "sourceUrls": [
      "https://platform.claude.com/docs/en/api/messages"
    ],
    "notes": "Model-dependent provider. Context and output token limits vary by the upstream endpoint and selected model, so 小酒馆 uses a number input instead of a fixed-limit slider."
  }
}
