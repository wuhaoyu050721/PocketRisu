{
  "id": "vertex-openai",
  "version": 5,
  "displayName": "Vertex AI (OpenAI-compatible)",
  "adapterKind": "openai-compatible",
  "authKinds": [
    "google-service-account"
  ],
  "endpointKinds": [
    "vertex-openai"
  ],
  "defaultHeaders": {
    "Content-Type": "application/json"
  },
  "defaultBody": {},
  "requestSchema": [
    {
      "key": "serviceAccountJson",
      "type": "string",
      "label": "Service Account JSON",
      "description": "Full Service Account JSON for OAuth token exchange.",
      "required": true,
      "secret": true,
      "mapsTo": {
        "target": "auth",
        "path": "apiKey"
      },
      "descriptionI18n": {
        "ko": "OAuth 토큰 교환용 Service Account 전체 JSON."
      }
    },
    {
      "key": "location",
      "type": "string",
      "label": "Location",
      "description": "Vertex AI region (e.g. us-central1, global). Defaults to global when left blank.",
      "required": false,
      "default": "global",
      "mapsTo": {
        "target": "custom",
        "path": "location"
      },
      "descriptionI18n": {
        "ko": "Vertex AI 리전 (예: us-central1, global). 비워두면 global이 됩니다."
      }
    },
    {
      "key": "projectId",
      "type": "string",
      "label": "Project ID",
      "description": "Google Cloud project id. Leave blank to use the project_id from the Service Account JSON.",
      "required": false,
      "mapsTo": {
        "target": "custom",
        "path": "project"
      },
      "descriptionI18n": {
        "ko": "Google Cloud 프로젝트 ID. 비워두면 Service Account JSON의 project_id를 사용합니다."
      }
    },
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Vertex OpenAI-compatible model id.",
      "required": true,
      "enum": [
        {
          "value": "google/gemini-3.5-flash",
          "label": "Google / Gemini 3.5 Flash"
        },
        {
          "value": "google/gemini-3.1-pro-preview",
          "label": "Google / Gemini 3.1 Pro"
        },
        {
          "value": "google/gemini-3.1-flash-lite",
          "label": "Google / Gemini 3.1 Flash-Lite"
        },
        {
          "value": "google/gemini-3-flash-preview",
          "label": "Google / Gemini 3 Flash"
        },
        {
          "value": "google/gemini-2.5-pro",
          "label": "Google / Gemini 2.5 Pro"
        },
        {
          "value": "google/gemini-2.5-flash",
          "label": "Google / Gemini 2.5 Flash"
        },
        {
          "value": "google/gemini-2.5-flash-lite",
          "label": "Google / Gemini 2.5 Flash-Lite"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "Vertex OpenAI 호환 모델 ID."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "min": 1,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      },
      "default": 8192
    },
    {
      "key": "frequency_penalty",
      "type": "number",
      "label": "Frequency Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "frequency_penalty"
      }
    },
    {
      "key": "presence_penalty",
      "type": "number",
      "label": "Presence Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "presence_penalty"
      }
    },
    {
      "key": "stop",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop"
      }
    },
    {
      "key": "seed",
      "type": "integer",
      "label": "Seed",
      "mapsTo": {
        "target": "body",
        "path": "seed"
      }
    },
    {
      "key": "reasoning_effort",
      "type": "string",
      "label": "Reasoning Effort",
      "description": "Reasoning depth. Maps to Gemini thinking_budget (2.5) / thinking_level (3.x).",
      "enum": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "reasoning_effort"
      },
      "descriptionI18n": {
        "ko": "추론(사고) 강도. Gemini thinking_budget(2.5)/thinking_level(3.x)로 매핑."
      }
    },
    {
      "key": "sharedRequestType",
      "type": "string",
      "label": "Shared Request Type",
      "description": "Vertex shared-quota processing tier. Flex is ~50% cheaper but higher-latency; Priority is premium pricing with consistent low latency. Only works on the global endpoint and select Gemini models. Provider default sends no header (Vertex standard).",
      "enum": [
        { "value": "", "label": "Provider default" },
        { "value": "flex", "label": "Flex" },
        { "value": "priority", "label": "Priority" }
      ],
      "mapsTo": {
        "target": "header",
        "path": "X-Vertex-AI-LLM-Shared-Request-Type"
      },
      "descriptionI18n": {
        "ko": "Vertex 공유 할당량 처리 등급. Flex는 약 50% 저렴하지만 지연이 높고, Priority는 프리미엄 과금에 일관된 저지연이에요. 글로벌 엔드포인트와 일부 Gemini 모델에서만 동작해요. 제공자 기본값은 헤더를 보내지 않아요(Vertex 표준)."
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "project",
        "label": "Project",
        "order": 2,
        "labelI18n": {
          "ko": "프로젝트"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 3,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 4,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 5,
        "labelI18n": {
          "ko": "추론"
        }
      },
      {
        "id": "quota",
        "label": "Quota",
        "order": 6,
        "labelI18n": {
          "ko": "할당량"
        }
      }
    ],
    "fields": [
      {
        "key": "serviceAccountJson",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "location",
        "widget": "text",
        "visibility": "basic",
        "group": "project",
        "order": 1
      },
      {
        "key": "projectId",
        "widget": "text",
        "visibility": "advanced",
        "group": "project",
        "order": 2
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1,
        "placeholder": "google/gemini-2.5-pro"
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "frequency_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "presence_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "stop",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 6
      },
      {
        "key": "seed",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 7
      },
      {
        "key": "reasoning_effort",
        "widget": "combobox",
        "visibility": "basic",
        "group": "reasoning",
        "order": 1
      },
      {
        "key": "sharedRequestType",
        "widget": "select",
        "visibility": "advanced",
        "group": "quota",
        "order": 1
      }
    ]
  },
  "capabilities": [
    "streaming",
    "reasoning",
    "vision",
    "tools"
  ],
  "sourceUrls": [
    "https://docs.cloud.google.com/vertex-ai/generative-ai/docs/start/openai",
    "https://docs.cloud.google.com/vertex-ai/generative-ai/docs/reference/rest/v1/projects.locations.endpoints.chat/completions"
  ],
  "limits": {
    "known": false,
    "sourceUrls": [
      "https://docs.cloud.google.com/vertex-ai/generative-ai/docs/start/openai",
      "https://docs.cloud.google.com/vertex-ai/generative-ai/docs/reference/rest/v1/projects.locations.endpoints.chat/completions"
    ],
    "notes": "Model-dependent provider. Context and output token limits vary by selected model or deployment, so 小酒馆 uses a number input instead of a fixed-limit slider."
  }
}
